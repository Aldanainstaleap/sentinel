# -----------------------------------------------------------------------------
# EXAMPLE ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in the values for your local development.
# In GitHub Codespaces, these values should be set as User Secrets.
# -----------------------------------------------------------------------------

# --- Server Configuration ---
# This variable refers to the port where the application server will run.
PORT=3000

# --- Service Identity ---
# The name of the service and the environment it is running in.
SERVICE_NAME="sentinel-service"
ENVIRONMENT="local"

# --- Authentication Configuration (AUTH_CONFIG) ---
# JSON object with settings for authentication services.
# - authType: The authentication strategy to use (I.e, "OAUTH2.0").
# - oauthConfig: Settings for your OAuth provider (I.e, Auth0).
#   - clientId, domain, audience: Values from your OAuth application.
#   - userEmailNameProperty: The claim in the JWT that contains the user's email.
# - apidocsUsers: A map of usernames to passwords for accessing the Swagger/OpenAPI documentation.
AUTH_CONFIG={"authType":"OAUTH2.0","oauthConfig":{"clientId":"<YOUR_OAUTH_CLIENT_ID>","domain":"<YOUR_OAUTH_DOMAIN>","audience":"<YOUR_OAUTH_AUDIENCE>","userEmailNameProperty":"https://your-app.com/email"}, "apidocsUsers":{"admin": "change-this-password"}}

# --- Gateway Configuration (GATEWAY_CONFIG) ---
# JSON object mapping downstream service names to their connection details.
# - headerName: The HTTP header used for service authentication.
# - baseUrl: The base URL of the downstream service.
# - secret: (Optional) The AWS Secrets Manager secret name for service tokens.
# - apiToken: (Optional) A static API token for the service.
GATEWAY_CONFIG={"redbook":{"headerName":"x-api-key","baseUrl":"https://redbook.xandar.instaleap.io"},"bifrost":{"headerName":"x-api-key","baseUrl":"https://api.xandar.instaleap.io"},"nebula":{"headerName":"Authorization","baseUrl":"https://nebula.xandar.instaleap.io","secret":"xandar/nebula/auth/password"},"tesseract":{"headerName":"Authorization","baseUrl":"https://tesseract-out.xandar.instaleap.io"},"antman":{"headerName":"Authorization","baseUrl":"https://antman.xandar.instaleap.io"},"dormammu":{"baseUrl":"https://dormammu.xandar.instaleap.io","headerName":"Authorization","apiToken":"nDhsfoQKxgHJpkh"},"nexus":{"baseUrl":"https://nexus.vormir.instaleap.io","headerName":"Authorization"},"kingpin":{"headerName":"Authorization","baseUrl":"https://kingpin.xandar.internal.instaleap.io"},"deadpool":{"baseUrl":"https://deadpool.xandar.instaleap.io","headerName":"Authorization"},"cerberus":{"baseUrl":"https://cerberus.xandar.instaleap.io","headerName":"Authorization"},"lola":{"baseUrl":"https://lola.xandar.instaleap.io","headerName":"Authorization"}}

# --- External Services Configuration (EXTERNAL_SERVICES_CONFIG) ---
# JSON object with credentials and settings for external services.
# - auth0: Auth0 Management API credentials per service (nexus, kingpin, lola).
EXTERNAL_SERVICES_CONFIG={"auth0":{"nexusAccessCredentials":{"clientId":"<NEXUS_AUTH0_CLIENT_ID>","clientSecret":"<NEXUS_AUTH0_CLIENT_SECRET>","audience":"<NEXUS_AUTH0_AUDIENCE>","domain":"<NEXUS_AUTH0_DOMAIN>"},"kingpinAccessCredentials":{"clientId":"<KINGPIN_AUTH0_CLIENT_ID>","clientSecret":"<KINGPIN_AUTH0_CLIENT_SECRET>","audience":"<KINGPIN_AUTH0_AUDIENCE>","domain":"<KINGPIN_AUTH0_DOMAIN>"},"lolaAccessCredentials":{"clientId":"<LOLA_AUTH0_CLIENT_ID>","clientSecret":"<LOLA_AUTH0_CLIENT_SECRET>","audience":"<LOLA_AUTH0_AUDIENCE>","domain":"<LOLA_AUTH0_DOMAIN>"}}}

# --- AWS Configuration (AWS_CONFIG) ---
# JSON object for AWS service configuration.
# - region: The default AWS region to use.
# - credentials: (Optional) For local development, you can provide explicit credentials.
#   In deployed environments, IAM roles are preferred and this should be omitted.
AWS_CONFIG={"region": "us-east-1", "credentials": {"accessKeyId": "<YOUR_AWS_ACCESS_KEY_ID>", "secretAccessKey": "<YOUR_AWS_SECRET_ACCESS_KEY>"}}

# --- CORS Configuration (CORS_CONFIG) ---
# JSON object to configure Cross-Origin Resource Sharing.
# - domainsWhiteList: An array of allowed origins. Use ["*"] for local development only.
#   For production, specify your frontend's domain: ["https://your-frontend.com"].
CORS_CONFIG={"domainsWhiteList": ["*"]}

# --- Node Package Manager Token (NPM_TOKEN) ---
# A GitHub Personal Access Token with 'read:packages' scope.
# Required to download private packages from GitHub Package Registry.
NPM_TOKEN="<YOUR_GITHUB_NPM_TOKEN>"

# --- GitHub Copilot CLI Token (COPILOT_GITHUB_TOKEN) ---
# A GitHub Personal Access Token (classic) with 'repo', 'user', and 'admin:org' scopes.
# Required for the 'gh copilot' CLI extension to authenticate within the dev container.
COPILOT_GITHUB_TOKEN="<YOUR_GITHUB_PAT_FOR_COPILOT>"
