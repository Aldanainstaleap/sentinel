{
  "name": "sentinel",
  "version": "1.0.0",
  "description": "API Gateway microservice based on Skrull template with Coulson gateway logic",
  "main": "dist/app.js",
  "engines": {
    "npm": ">=8.9.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest --coverage",
    "build": "npx rimraf dist && npm run build-ts",
    "build-ts": "tsc",
    "prepare": "husky",
    "start:dev": "nodemon -L --ignore node_modules src/app.ts",
    "start": "node dist/app.js",
    "dev:debug": "ts-node-dev --transpile-only --respawn --ignore node_modules src/app.ts --inspect=0.0.0.0:9229",
    "test:debug": "vitest --coverage --inspect=0.0.0.0:9229"
  },
  "keywords": [
    "gateway",
    "skrull",
    "coulson"
  ],
  "author": "Aldanainstaleap",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash": "^4.17.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.1",
    "eslint-config-love": "^119.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.5",
    "prettier": "3.2.5",
    "supertest": "^7.1.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.876.0",
    "@mercadoni/instaleap-utils": "^4.17.0",
    "@types/memory-cache": "^0.2.6",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "memory-cache": "^0.2.0",
    "nodemon": "^3.1.10",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0"
  }
}
